#############################################################
# 默认配置，如有修改请同步其他配置文件（需要同步的项会在注释中标出）
# !!! 为建议修改项
#############################################################


# python程序连接mysql数据库的用户名，如有修改请同步更改conf/mysql-init.sql内第111,112行
MYSQL_DB_USER=mysql_user

# python程序连接mysql数据库的端口
MYSQL_DB_PORT=3306

# python程序连接mysql数据库的数据库名，如有修改请同步更改conf/mysql-init.sql 内第5,6行
MYSQL_DB_NAME=vmcontrolhub

# python程序连接mysql数据库的主机名，如有修改请同步更改docker-compose.yml内第2行
MYSQL_DB_HOST=mysql

# !!!
# python程序连接mysql数据库的密码，如有修改请同步更改conf/mysql-init.sql内第113行
MYSQL_DB_PASSWORD=123456

# python程序连接mysql数据库的表名
MYSQL_DB_TABLE_CHANGE_LOGS=change_logs
MYSQL_DB_TABLE_HOSTS=hosts
MYSQL_DB_TABLE_OPERATION_LOGS=operation_logs
MYSQL_DB_TABLE_USERS=users
MYSQL_DB_TABLE_VMS=vms

# !!!
# SSH宿主机时使用的用户，可以替换为被管理主机实际拥有的相同用户
SSH_USER=vmcontrolhub

# SSH宿主机时使用的私钥文件路径
SSH_KEY_FILE=/home/vmcontrolhub/.ssh/id_rsa

# !!!
# admin角色重置其他用户密码时使用的密码
TEMP_PASSWORD=admin@123

# !!!
# 加密密钥，建议使用随机字符串，实际使用时请更改为安全的密码
SECRET_KEY=da266a3ffc9da06043dff80df46e3a59b3179a6b9f0b7d8b3994e15917764cf2d5b81523dbf30ec1d3a3cbfec459197a11814a796351158b38edee92496de7ca 