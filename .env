#################################
#########     默认配置       ####
######### 不含!!!为可修改项  #####
#################################

# Nginx宿主机端口（默认80）
NGINX_HOST_PORT=80

# admin角色重置其他用户密码后，其他用户的临时密码
TEMP_PASSWORD=admin@123

# SSH宿主机时使用的用户，可以替换为被管理主机实际拥有的相同用户
SSH_USER=vmcontrolhub

# 加密密钥，建议使用随机字符串，实际使用时请更改为安全的密码
SECRET_KEY=da266a3ffc9da06043dff80df46e3a59b3179a6b9f0b7d8b3994e15917764cf2d5b81523dbf30ec1d3a3cbfec459197a11814a796351158b38edee92496de7ca

# !!!
# python程序连接mysql数据库的主机名(docker-compose.yml的mylsql容器的service name)
MYSQL_DB_HOST=mysql

# !!!
# python程序连接mysql数据库的端口
MYSQL_DB_PORT=3306

# !!!
# python程序连接mysql数据库的用户名
MYSQL_DB_USER=vmcontrolhub

# !!!
# python程序连接mysql数据库的数据库名
MYSQL_DB_NAME=vmcontrolhub

# !!!
# python程序连接mysql数据库的密码
MYSQL_DB_PASSWORD=vmcontrolhub

# !!!
# 程序SSH宿主机时使用的容器内私钥文件路径
SSH_KEY_FILE=/home/vmcontrolhub/.ssh/id_rsa